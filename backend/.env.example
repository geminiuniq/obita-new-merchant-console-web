# Copy to .env and fill in real secrets for non-mock providers.
# Never commit .env. All MVP-default values map to docker-compose.

# --- Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/obita
SPRING_DATASOURCE_USERNAME=obita
SPRING_DATASOURCE_PASSWORD=obita_dev_pwd

# --- Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=obita_dev_pwd

# --- RocketMQ
ROCKETMQ_NAME_SERVER=localhost:9876
ROCKETMQ_PRODUCER_GROUP=obita-mvp-producer

# --- Auth
OBITA_AUTH_JWT_SECRET=change_me_to_a_64_char_random_string_______________________________
OBITA_AUTH_ACCESS_TTL=PT15M
OBITA_AUTH_REFRESH_TTL=P14D

# --- Web3 / Custody (mock by default)
OBITA_CUSTODY_PROVIDER=mock
OBITA_BRIDGE_PROVIDER=mock
OBITA_FIAT_RAMP_PROVIDER=mock

# --- Real providers (placeholders for handoff stage)
OBITA_COBO_API_KEY=
OBITA_COBO_API_SECRET=
OBITA_CIRCLE_API_KEY=
OBITA_LAYERZERO_ENDPOINT=

# --- Chain RPCs (used only when adapters point at real chains; MVP defaults are testnets)
OBITA_RPC_ETH=https://eth-sepolia.g.alchemy.com/v2/demo
OBITA_RPC_BSC=https://data-seed-prebsc-1-s1.binance.org:8545
OBITA_RPC_POLYGON=https://rpc-amoy.polygon.technology
OBITA_RPC_TRON=https://api.shasta.trongrid.io
